project_id          = "olaba-lis-prod"
project_name        = "Olaba LIS Production"
billing_account     = "000000-000000-000000"
region              = "europe-west4"
cloudflare_zone_id  = "YOUR_CLOUDFLARE_ZONE_ID"
cloudflare_api_token = "YOUR_CLOUDFLARE_API_TOKEN"
domain              = "olaba-lis.com"
root_subdomain      = "app"

tenant_hosts = [
  "app.olaba-lis.com",
  "lab01.olaba-lis.com",
  "lab02.olaba-lis.com"
]

enable_binary_authorization = false

deletion_protection = true

labels = {
  app         = "senaite"
  owner       = "olaba"
  managed_by  = "terraform"
  environment = "prod"
  cost_center = "lab-platform"
}
